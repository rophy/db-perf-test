          "expr": "max by (instance) (irate(node_network_transmit_bytes_total{device!=\"lo\", job=\"node-exporter\", run_id=~\"$run_id\"}[$__rate_interval])) / 1024 / 1024",
          "legendFormat": "{{instance}} TX"
        }
