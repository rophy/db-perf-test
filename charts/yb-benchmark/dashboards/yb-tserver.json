      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{job=\"node-exporter\", run_id=~\"$run_id\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\", run_id=~\"$run_id\"}) / 1024 / 1024",
          "legendFormat": "{{instance}}"
        }
      ],
