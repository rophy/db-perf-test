          "expr": "sum by (instance) (irate(node_disk_reads_completed_total{device!~\"loop.*|dm-.*\", job=\"node-exporter\", run_id=~\"$run_id\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} read"
