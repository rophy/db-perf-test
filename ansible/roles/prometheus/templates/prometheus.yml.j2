global:
  scrape_interval: 5s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
        - "localhost:9090"

  - job_name: yb-tserver
    metrics_path: /prometheus-metrics
    static_configs:
      - targets:
{% for host in groups['yb_tservers'] %}
        - "{{ hostvars[host].ansible_host }}:9000"
{% endfor %}

  - job_name: yb-master
    metrics_path: /prometheus-metrics
    static_configs:
      - targets:
{% for master in yb_masters %}
        - "{{ hostvars[groups['control'][0]].ansible_host }}:{{ master.web_port }}"
{% endfor %}

  - job_name: node-exporter
    static_configs:
      - targets:
{% for host in groups['all'] %}
        - "{{ hostvars[host].ansible_host }}:9200"
{% endfor %}
