#!/bin/bash
# k6 environment variables for vm-virsh target
# Source this before running k6: . /opt/bench/k6/env.sh

export PG_HOST="{{ hostvars[groups['yb_tservers'][0]].ansible_host }}"
export PG_PORT="{{ db_port }}"
export PG_USER="{{ db_user }}"
export PG_PASS="{{ db_password }}"
export PG_DB="{{ db_name }}"

export K6_TABLES="{{ k6_tables }}"
export K6_TABLE_SIZE="{{ k6_table_size }}"
export K6_CREATE_SECONDARY="{{ k6_create_secondary | lower }}"
export K6_INSTALL_TRIGGER="{{ k6_install_trigger | lower }}"
export K6_SERIAL_CACHE_SIZE="{{ k6_serial_cache_size }}"

export BENCH_VUS="{{ k6_vus }}"
export BENCH_WARMUP="{{ k6_warmup_time }}"
export BENCH_DURATION="{{ k6_duration }}"

export K6_PROMETHEUS_RW_SERVER_URL="http://localhost:9090/api/v1/write"
export K6_PROMETHEUS_RW_TREND_STATS="p(95),p(99),min,max,avg"
